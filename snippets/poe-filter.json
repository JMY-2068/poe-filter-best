{
  "Show Block": {
    "scope": "poe-filter",
    "prefix": "show",
    "body": [
      "Show # ${1:描述}",
      "    ${2:Class \"${3:Class Name}\"}",
      "    ${0}"
    ],
    "description": "创建一个 Show block（显示匹配物品）"
  },
  "Hide Block": {
    "scope": "poe-filter",
    "prefix": "hide",
    "body": [
      "Hide # ${1:描述}",
      "    ${2:Class \"${3:Class Name}\"}",
      "    ${0}"
    ],
    "description": "创建一个 Hide block（隐藏匹配物品）"
  },
  "Currency Block": {
    "scope": "poe-filter",
    "prefix": "currency",
    "body": [
      "Show # ${1:高价值通货}",
      "    Class \"Currency\"",
      "    BaseType ${2:\"Exalted Orb\" \"Divine Orb\" \"Mirror of Kalandra\"}",
      "    SetTextColor 255 255 255",
      "    SetBackgroundColor 255 0 0",
      "    SetBorderColor 255 255 255",
      "    SetFontSize 45",
      "    MinimapIcon 2 Red Star",
      "    PlayEffect Red",
      "    PlayAlertSound 1 300"
    ],
    "description": "通货高亮显示 block"
  },
  "Unique Item Block": {
    "scope": "poe-filter",
    "prefix": "unique",
    "body": [
      "Show # ${1:传奇物品}",
      "    Rarity Unique",
      "    SetTextColor 175 96 37",
      "    SetBackgroundColor 65 35 20",
      "    SetBorderColor 175 96 37",
      "    SetFontSize ${2:42}",
      "    MinimapIcon 1 Brown Star"
    ],
    "description": "传奇物品高亮显示 block"
  },
  "Map Tier Block": {
    "scope": "poe-filter",
    "prefix": "map",
    "body": [
      "Show # ${1:高阶地图}",
      "    Class \"Map\"",
      "    MapTier >= ${2:11}",
      "    SetTextColor 0 0 0",
      "    SetBackgroundColor 255 255 255",
      "    SetBorderColor 0 0 0",
      "    SetFontSize 42",
      "    MinimapIcon 2 White Star",
      "    PlayEffect White"
    ],
    "description": "地图过滤 block（按阶级）"
  },
  "Divination Card Block": {
    "scope": "poe-filter",
    "prefix": "divcard",
    "body": [
      "Show # ${1:命运卡}",
      "    Class \"Divination Card\"",
      "    SetTextColor 0 255 255",
      "    SetBackgroundColor 30 30 30",
      "    SetBorderColor 0 255 255",
      "    SetFontSize ${2:42}",
      "    MinimapIcon 1 Cyan Triangle"
    ],
    "description": "命运卡高亮显示 block"
  },
  "Gem Block": {
    "scope": "poe-filter",
    "prefix": "gem",
    "body": [
      "Show # ${1:高品质宝石}",
      "    Class \"Gem\"",
      "    Quality >= ${2:15}",
      "    SetTextColor 0 255 0",
      "    SetBackgroundColor 0 0 0",
      "    SetBorderColor 0 255 0",
      "    SetFontSize 40"
    ],
    "description": "品质宝石过滤 block"
  },
  "Rare Item Block": {
    "scope": "poe-filter",
    "prefix": "rare",
    "body": [
      "Show # ${1:稀有物品}",
      "    Rarity Rare",
      "    ItemLevel >= ${2:75}",
      "    SetTextColor 255 255 119",
      "    SetBackgroundColor 0 0 0",
      "    SetBorderColor 255 255 119",
      "    SetFontSize ${3:36}"
    ],
    "description": "稀有物品过滤 block（按等级）"
  },
  "6-Link Block": {
    "scope": "poe-filter",
    "prefix": "6link",
    "body": [
      "Show # 6连物品",
      "    LinkedSockets = 6",
      "    SetTextColor 0 0 0",
      "    SetBackgroundColor 255 0 0",
      "    SetBorderColor 255 255 255",
      "    SetFontSize 45",
      "    MinimapIcon 2 Red Diamond",
      "    PlayEffect Red",
      "    PlayAlertSound 1 300"
    ],
    "description": "6连物品高亮显示 block"
  },
  "Socket Group Block": {
    "scope": "poe-filter",
    "prefix": "socketgroup",
    "body": [
      "Show # ${1:孔色组合}",
      "    SocketGroup ${2:RRRR}"
    ],
    "description": "按孔色组合过滤 block"
  },
  "Color Preset - Gold": {
    "scope": "poe-filter",
    "prefix": "color-gold",
    "body": [
      "SetTextColor 255 255 255",
      "SetBackgroundColor 180 160 40",
      "SetBorderColor 255 255 255",
      "SetFontSize 45"
    ],
    "description": "金色配色方案（高价值物品）"
  },
  "Color Preset - Red": {
    "scope": "poe-filter",
    "prefix": "color-red",
    "body": [
      "SetTextColor 255 255 255",
      "SetBackgroundColor 255 0 0",
      "SetBorderColor 255 255 255",
      "SetFontSize 45"
    ],
    "description": "红色配色方案（极高价值物品）"
  },
  "Color Preset - Green": {
    "scope": "poe-filter",
    "prefix": "color-green",
    "body": [
      "SetTextColor 0 0 0",
      "SetBackgroundColor 0 255 0",
      "SetBorderColor 0 0 0",
      "SetFontSize 42"
    ],
    "description": "绿色配色方案（有价值物品）"
  },
  "Color Preset - Blue": {
    "scope": "poe-filter",
    "prefix": "color-blue",
    "body": [
      "SetTextColor 0 0 0",
      "SetBackgroundColor 100 100 255",
      "SetBorderColor 0 0 0",
      "SetFontSize 40"
    ],
    "description": "蓝色配色方案（一般物品）"
  },
  "Full Visual Style": {
    "scope": "poe-filter",
    "prefix": "visual",
    "body": [
      "SetTextColor ${1:255} ${2:255} ${3:255}",
      "SetBackgroundColor ${4:0} ${5:0} ${6:0}",
      "SetBorderColor ${7:255} ${8:255} ${9:255}",
      "SetFontSize ${10:40}",
      "MinimapIcon ${11|0,1,2|} ${12|Red,Green,Blue,Brown,White,Yellow|} ${13|Circle,Diamond,Hexagon,Square,Star,Triangle,Cross,Pentagon,Kite|}",
      "PlayEffect ${14|Red,Green,Blue,Brown,White,Yellow|}",
      "PlayAlertSound ${15:1} ${16:300}"
    ],
    "description": "完整视觉效果设置（颜色+图标+光柱+音效）"
  }
}
