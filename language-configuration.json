{
  "comments": {
    "lineComment": "#"
  },
  "brackets": [
    ["\"", "\""]
  ],
  "autoClosingPairs": [
    { "open": "\"", "close": "\"", "notIn": ["string"] }
  ],
  "surroundingPairs": [
    ["\"", "\""]
  ],
  "folding": {
    "markers": {
      "start": "^\\s*(Show|Hide)\\b",
      "end": "^\\s*$"
    }
  },
  "indentationRules": {
    "increaseIndentPattern": "^\\s*(Show|Hide)\\b",
    "decreaseIndentPattern": "^\\s*$"
  }
}
