{
  "name": "poe-filter-best",
  "displayName": "POE Filter Best",
  "description": "Path of Exile loot filter file support — syntax highlighting, formatting, smart editing, completion, diagnostics, and hover",
  "version": "0.5.0",
  "publisher": "JMY-2068",
  "license": "MIT",
  "icon": "icon.png",
  "galleryBanner": {
    "color": "#1e1e2e",
    "theme": "dark"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/JMY-2068/poe-filter-best"
  },
  "bugs": {
    "url": "https://github.com/JMY-2068/poe-filter-best/issues"
  },
  "homepage": "https://github.com/JMY-2068/poe-filter-best#readme",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages",
    "Formatters"
  ],
  "keywords": [
    "poe",
    "path of exile",
    "loot filter",
    "filter"
  ],
  "activationEvents": [
    "onLanguage:poe-filter"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "configuration": {
      "title": "POE Filter Best",
      "properties": {
        "poe-filter-best.sectionSeparator": {
          "type": "string",
          "default": " - ",
          "description": "大纲视图中 block 注释的层级分隔符（用于 Show # 一级 - 二级 - 三级 格式）"
        }
      }
    },
    "languages": [
      {
        "id": "poe-filter",
        "aliases": [
          "POE Filter",
          "Path of Exile Filter"
        ],
        "extensions": [
          ".filter"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "poe-filter",
        "scopeName": "source.poe-filter",
        "path": "./syntaxes/poe-filter.tmLanguage.json"
      }
    ],
    "snippets": [
      {
        "language": "poe-filter",
        "path": "./snippets/poe-filter.json"
      }
    ],
    "commands": [
      {
        "command": "poe-filter-best.formatDocument",
        "title": "POE Filter: Format Document"
      },
      {
        "command": "poe-filter-best.formatSelection",
        "title": "POE Filter: Format Selection"
      },
      {
        "command": "poe-filter-best.toggleBlock",
        "title": "POE Filter: Toggle Block"
      },
      {
        "command": "poe-filter-best.showBlockCustom",
        "title": "POE Filter: Show Block (Custom Sound)"
      },
      {
        "command": "poe-filter-best.showBlockSystem",
        "title": "POE Filter: Show Block (System Sound)"
      },
      {
        "command": "poe-filter-best.hideBlock",
        "title": "POE Filter: Hide Block"
      },
      {
        "command": "poe-filter-best.disableBlock",
        "title": "POE Filter: Disable Block"
      },
      {
        "command": "poe-filter-best._codeLensAction",
        "title": "POE Filter: CodeLens Action (internal)"
      }
    ],
    "keybindings": [
      {
        "command": "poe-filter-best.toggleBlock",
        "key": "ctrl+b ctrl+t",
        "when": "editorTextFocus && editorLangId == poe-filter"
      },
      {
        "command": "poe-filter-best.showBlockCustom",
        "key": "ctrl+b ctrl+s",
        "when": "editorTextFocus && editorLangId == poe-filter"
      },
      {
        "command": "poe-filter-best.showBlockSystem",
        "key": "ctrl+b ctrl+y",
        "when": "editorTextFocus && editorLangId == poe-filter"
      },
      {
        "command": "poe-filter-best.hideBlock",
        "key": "ctrl+b ctrl+h",
        "when": "editorTextFocus && editorLangId == poe-filter"
      },
      {
        "command": "poe-filter-best.disableBlock",
        "key": "ctrl+b ctrl+d",
        "when": "editorTextFocus && editorLangId == poe-filter"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "poe-filter-best.toggleBlock",
          "when": "editorLangId == poe-filter",
          "group": "1_poe-filter@1"
        },
        {
          "command": "poe-filter-best.showBlockCustom",
          "when": "editorLangId == poe-filter",
          "group": "1_poe-filter@2"
        },
        {
          "command": "poe-filter-best.showBlockSystem",
          "when": "editorLangId == poe-filter",
          "group": "1_poe-filter@3"
        },
        {
          "command": "poe-filter-best.hideBlock",
          "when": "editorLangId == poe-filter",
          "group": "1_poe-filter@4"
        },
        {
          "command": "poe-filter-best.disableBlock",
          "when": "editorLangId == poe-filter",
          "group": "1_poe-filter@4"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src --ext ts"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.4.0"
  }
}
