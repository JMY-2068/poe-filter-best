{
  "name": "poe-filter-best",
  "displayName": "一乐过滤本地编辑增强",
  "description": "一款适用于一乐过滤本地编辑的增强扩展插件,提供语法高亮,格式化,智能补全,语法校验,悬停提示,效果预览,批量改色等功能,大幅提升本地过滤编辑体验",
  "version": "1.0.0",
  "publisher": "JMY-2068",
  "license": "MIT",
  "icon": "icon.png",
  "galleryBanner": {
    "color": "#1e1e2e",
    "theme": "dark"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/JMY-2068/poe-filter-best"
  },
  "bugs": {
    "url": "https://github.com/JMY-2068/poe-filter-best/issues"
  },
  "homepage": "https://github.com/JMY-2068/poe-filter-best#readme",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages",
    "Formatters"
  ],
  "keywords": [
    "poe",
    "path of exile",
    "loot filter",
    "filter"
  ],
  "activationEvents": [
    "onLanguage:poe-filter"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "configurationDefaults": {
      "[poe-filter]": {
        "editor.quickSuggestions": {
          "other": true,
          "comments": false,
          "strings": false
        },
        "editor.wordBasedSuggestions": "off"
      }
    },
    "configuration": {
      "title": "POE Filter Best",
      "properties": {
        "poe-filter-best.sectionSeparator": {
          "type": "string",
          "default": " - ",
          "description": "大纲视图中 block 注释的层级分隔符（用于 Show # 一级 - 二级 - 三级 格式）"
        },
        "poe-filter-best.panelDensity": {
          "type": "string",
          "default": "comfortable",
          "enum": ["compact", "normal", "comfortable"],
          "enumDescriptions": ["紧凑 — 最小间距", "标准 — 默认间距", "宽松 — 最大间距"],
          "description": "Block Explorer 面板行间距密度"
        },
        "poe-filter-best.parameterPickerCodeLens": {
          "type": "boolean",
          "default": false,
          "description": "显示 MinimapIcon / PlayEffect 行的参数选择器 CodeLens 按钮（📐大小 🎨颜色 ⬡形状），默认关闭"
        }
      }
    },
    "languages": [
      {
        "id": "poe-filter",
        "aliases": [
          "POE Filter",
          "Path of Exile Filter"
        ],
        "extensions": [
          ".filter"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "poe-filter",
        "scopeName": "source.poe-filter",
        "path": "./syntaxes/poe-filter.tmLanguage.json"
      }
    ],
    "commands": [
      {
        "command": "poe-filter-best.formatDocument",
        "title": "POE Filter: Format Document"
      },
      {
        "command": "poe-filter-best.formatSelection",
        "title": "POE Filter: Format Selection"
      },
      {
        "command": "poe-filter-best.toggleBlock",
        "title": "POE Filter: Toggle Block"
      },
      {
        "command": "poe-filter-best.showBlockCustom",
        "title": "POE Filter: Show Block (Custom Sound)"
      },
      {
        "command": "poe-filter-best.showBlockSystem",
        "title": "POE Filter: Show Block (System Sound)"
      },
      {
        "command": "poe-filter-best.hideBlock",
        "title": "POE Filter: Hide Block"
      },
      {
        "command": "poe-filter-best.disableBlock",
        "title": "POE Filter: Disable Block"
      },
      {
        "command": "poe-filter-best._codeLensAction",
        "title": "POE Filter: CodeLens Action (internal)"
      },
      {
        "command": "poe-filter-best.toggleSoundMode",
        "title": "POE Filter: Toggle Sound Mode",
        "icon": {
          "light": "resources/icons/sound-light.svg",
          "dark": "resources/icons/sound-dark.svg"
        }
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "poe-filter-explorer",
          "title": "POE Filter",
          "icon": "icon.svg"
        }
      ]
    },
    "views": {
      "poe-filter-explorer": [
        {
          "type": "webview",
          "id": "poe-filter-best.blockPanel",
          "name": "Blocks"
        }
      ]
    },
    "menus": {
      "editor/title": [
        {
          "command": "poe-filter-best.toggleSoundMode",
          "when": "editorLangId == poe-filter",
          "group": "navigation"
        }
      ],
      "editor/context": [
        {
          "command": "poe-filter-best.toggleBlock",
          "when": "editorLangId == poe-filter",
          "group": "1_poe-filter@1"
        },
        {
          "command": "poe-filter-best.showBlockCustom",
          "when": "editorLangId == poe-filter",
          "group": "1_poe-filter@2"
        },
        {
          "command": "poe-filter-best.showBlockSystem",
          "when": "editorLangId == poe-filter",
          "group": "1_poe-filter@3"
        },
        {
          "command": "poe-filter-best.hideBlock",
          "when": "editorLangId == poe-filter",
          "group": "1_poe-filter@4"
        },
        {
          "command": "poe-filter-best.disableBlock",
          "when": "editorLangId == poe-filter",
          "group": "1_poe-filter@4"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src --ext ts"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.4.0"
  }
}
